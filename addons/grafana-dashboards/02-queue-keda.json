        "query": "hailcast",
        "current": {
          "text": "hailcast",
          "value": "hailcast"
        },
        "hide": 0
      },
      {
        "name": "worker_deployment",
        "label": "Worker Deployment",
        "type": "constant",
        "query": "hailcast-worker",
        "current": {
          "text": "hailcast-worker",
          "value": "hailcast-worker"
        },
        "hide": 0
      },
      {
        "name": "predict_service",
        "label": "Predict Service",
        "type": "constant",
        "query": "predict",
        "current": {
          "text": "predict",
          "value": "predict"
        },
        "hide": 0
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
