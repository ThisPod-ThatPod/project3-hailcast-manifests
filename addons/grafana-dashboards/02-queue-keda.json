{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Reactive Scaling Summary",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "title": "Queue Backlog",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "ьўёВъг PrometheusВЌљ ВѕўВДЉвљю hailcast_queue_size Ж░њВЮ┤вІц. ВъёВЮўВЮў ВъЦВЋа thresholdвіћ ВаЂВџЕьЋўВДђ ВЋівіћвІц.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(hailcast_queue_size{namespace=\"$namespace\"})",
          "legendFormat": "Queue backlog",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 10,
      "title": "HPA Max Replica",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Worker KEDA HPAВЌљ ВёцВаЋвљю spec.maxReplicas Ж░њВЮ┤вІц.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  kube_horizontalpodautoscaler_spec_max_replicas{\n    namespace=\"$namespace\",\n    horizontalpodautoscaler=\"keda-hpa-hailcast-worker-scaler\"\n  }\n)",
          "legendFormat": "Maximum",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "mappings": []
      },
      "overrides": []
    },
    "options": {
      "colorMode": "none",
      "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 11,
      "title": "KEDA Operator Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "kube-state-metrics ЖИ░Вцђ KEDA operator DeploymentВЌљ available replicaЖ░ђ ВъѕвіћВДђ ьЉюВІюьЋювІц.",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "(\n  max(\n    kube_deployment_status_replicas_available{\n      namespace=\"keda\",\n      deployment=\"keda-operator\"\n    }\n  )\n  or vector(0)\n) > bool 0",
          "legendFormat": "KEDA Operator",
          "refId": "A",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "index": 0,
                  "text": "Down"
                },
                "1": {
                  "color": "green",
                  "index": 1,
                  "text": "Healthy"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name",
        "wideLayout": true
      }
    },
    {
      "id": 6,
      "title": "Reactive Scaling Timeline",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "panels": []
    },
    {
      "id": 12,
      "title": "Queue / HPA / Worker",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "вЈЎВЮ╝ ВІюЖ░ёВХЋВЌљВёю queue backlog, ВаЂВџЕ baseline, HPA desired/current, Worker ReadyВЮў в░ўВЮЉВЮё в╣ёЖхљьЋювІц. Queueвіћ ВўцвЦИВфй ВХЋ, replica Ж│ёВЌ┤ВЮђ ВЎ╝Вфй ВХЋВЮ┤вІц.",
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(hailcast_queue_size{namespace=\"$namespace\"})",
          "legendFormat": "Queue backlog",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  kube_horizontalpodautoscaler_spec_min_replicas{\n    namespace=\"$namespace\",\n    horizontalpodautoscaler=\"keda-hpa-hailcast-worker-scaler\"\n  }\n)",
          "legendFormat": "Applied baseline",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  kube_horizontalpodautoscaler_status_desired_replicas{\n    namespace=\"$namespace\",\n    horizontalpodautoscaler=\"keda-hpa-hailcast-worker-scaler\"\n  }\n)",
          "legendFormat": "HPA desired",
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  kube_horizontalpodautoscaler_status_current_replicas{\n    namespace=\"$namespace\",\n    horizontalpodautoscaler=\"keda-hpa-hailcast-worker-scaler\"\n  }\n)",
          "legendFormat": "HPA current",
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  kube_deployment_status_replicas_ready{\n    namespace=\"$namespace\",\n    deployment=\"$worker_deployment\"\n  }\n)",
          "legendFormat": "Worker ready",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [],
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Replicas",
            "axisPlacement": "left",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Queue backlog"
            },
              "properties": [
                {
                  "id": "custom.axisPlacement",
                  "value": "right"
                },
                {
                  "id": "custom.axisLabel",
                  "value": "Queue backlog"
                },
                {
                  "id": "custom.drawStyle",
                "value": "bars"
              },
              {
                "id": "custom.fillOpacity",
                "value": 18
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "title": "Pending Worker / Ready Node",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Pending WorkerВЎђ Ready Node ВѕўвЦ╝ Ж░ЎВЮђ ВІюЖ░ёВХЋВЌљВёю в╣ёЖхљьЋювІц. Pending WorkerЖ░ђ 1 ВЮ┤ВЃЂВЮ┤вЕ┤ scheduling ВДђВЌ░ Ж░ђвіЦВё▒ВЮё ВаљЖ▓ђьЋ┤ВЋ╝ ьЋювІц. NodeClaimВЮё ВДЂВаЉ Ж┤ђВИАьЋўвіћ ьїевёљВЮђ ВЋёвІѕвІц.",
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(\n  kube_pod_status_phase{\n    namespace=\"$namespace\",\n    pod=~\"${worker_deployment}-.*\",\n    phase=\"Pending\"\n  }\n)",
          "legendFormat": "Pending worker",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(\n  kube_node_status_condition{\n    condition=\"Ready\",\n    status=\"true\"\n  }\n)",
          "legendFormat": "Ready nodes",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "mappings": [],
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 8,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 14,
      "title": "Queue Detail",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 19
      },
      "panels": []
    },
    {
      "id": 3,
      "title": "Queue Maximum (5m)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "ВхюЖи╝ 5вХё hailcast_queue_sizeВЮў ВхювїђЖ░њВЮ┤вІц. ВъёВЮўВЮў Ж▓йв│┤ ВъёЖ│ёЖ░њВЮђ ВаЂВџЕьЋўВДђ ВЋівіћвІц.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(\n  max_over_time(\n    hailcast_queue_size{namespace=\"$namespace\"}[5m]\n  )\n)",
          "legendFormat": "Maximum",
          "refId": "A"
        }
      ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "mappings": []
      },
      "overrides": []
    },
    "options": {
      "colorMode": "none",
      "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 4,
      "title": "Queue Change (5m)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "ьўёВъг queue backlogВЎђ 5вХё Ваё Ж░њВЮё в╣ёЖхљьЋювІц. series ВЃЮВё▒ ьЏё 5вХёВЮ┤ ВДђвѓўВДђ ВЋіВЋўЖ▒░вѓў Ж│╝Ж▒░ seriesЖ░ђ ВЌєВю╝вЕ┤ No DataВЮ╝ Вѕў ВъѕвІц.",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(hailcast_queue_size{namespace=\"$namespace\"})\n-\nmax(hailcast_queue_size{namespace=\"$namespace\"} offset 5m)",
          "legendFormat": "Queue Change",
          "refId": "A"
        }
      ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "mappings": []
      },
      "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "hideZeros": false,
          "mode": "multi",
          "sort": "none"
        }
      }
    }
  ],
