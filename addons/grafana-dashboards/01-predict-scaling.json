          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(\n  kube_pod_status_ready{\n    namespace=\"$namespace\",\n    pod=~\"predict-.*\",\n    condition=\"true\"\n  }\n)",
